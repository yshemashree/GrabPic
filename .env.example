# Copy to .env before running docker compose
DATABASE_URL=postgresql+asyncpg://grabpic:grabpic@postgres:5432/grabpic
SYNC_DATABASE_URL=postgresql+psycopg2://grabpic:grabpic@postgres:5432/grabpic
REDIS_URL=redis://redis:6379/0
QDRANT_URL=http://qdrant:6333
MINIO_ENDPOINT=minio:9000
MINIO_PUBLIC_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=grabpic
MINIO_SECRET_KEY=grabpic-secret
MINIO_BUCKET=grabpic
MINIO_SECURE=false

# Matching thresholds (cosine similarity)
CONFIDENT_THRESHOLD=0.5
BORDERLINE_THRESHOLD=0.35

# Quality gates
BLUR_THRESHOLD=60.0
PHASH_DISTANCE=4
MAX_UPLOAD_MB=25

# Rate limiting
SEARCH_RATE_LIMIT=10/minute

CORS_ORIGINS=http://localhost:3000
