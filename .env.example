# Copy to .env and fill in your own Supabase + Qdrant Cloud credentials.
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_DB_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres
SYNC_DATABASE_URL=postgresql+psycopg2://postgres:YOUR_DB_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

QDRANT_URL=https://YOUR_CLUSTER.cloud.qdrant.io:6333
QDRANT_API_KEY=

SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_KEY=
SUPABASE_BUCKET=grabpic

# Matching thresholds (cosine similarity)
CONFIDENT_THRESHOLD=0.5
BORDERLINE_THRESHOLD=0.35

# Quality gates
BLUR_THRESHOLD=60.0
PHASH_DISTANCE=4
MAX_UPLOAD_MB=25

# Rate limiting
SEARCH_RATE_LIMIT=10/minute

CORS_ORIGINS=http://localhost:3000
